{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "ember-mod",
  "permissions": {
    "reddit": {
      "enable": true,
      "scope": "moderator"
    },
    "redis": true
  },
  "blocks": {
    "entry": "src/main.tsx",
    "settings": {
      "enable": true
    },
    "triggers": [
      "onPostSubmit",
      "onCommentSubmit",
      "onPostReport",
      "onCommentReport",
      "onModAction",
      "onAppInstall",
      "onAppUpgrade"
    ]
  },
  "post": {
    "dir": "webroot",
    "entrypoints": {
      "default": {
        "entry": "ember-radar.html",
        "height": "regular"
      }
    }
  },
  "media": {
    "dir": "assets"
  },
  "marketingAssets": {
    "icon": "assets/$devvit_icon.png"
  },
  "dev": {
    "subreddit": "ember_mod_dev"
  }
}